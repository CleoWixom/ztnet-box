#!/bin/sh
set -e

case "$1" in
  remove|upgrade|deconfigure)
    if systemctl is-active ztnet-box.service >/dev/null 2>&1; then
      systemctl stop ztnet-box.service || true
    fi
    ;;
  failed-upgrade)
    ;;
  *)
    echo "prerm called with unknown argument '$1'" >&2
    exit 1
    ;;
esac

exit 0
