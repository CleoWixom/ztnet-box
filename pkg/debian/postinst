#!/bin/sh
set -e

case "$1" in
  configure)
    systemctl daemon-reload || true
    if systemctl is-enabled ztnet-box.service >/dev/null 2>&1; then
      systemctl restart ztnet-box.service || true
    fi
    ;;
  abort-upgrade|abort-remove|abort-deconfigure)
    ;;
  *)
    echo "postinst called with unknown argument '$1'" >&2
    exit 1
    ;;
esac

exit 0
